{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).(webp|png|ico|txt|xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/inquire",
      "destination": "/api/inquire"
    },
    {
      "source": "/((?!assets/|videos/|images/|api/|logo|pinebrook|robots.txt|sitemap.xml|favicon).*)",
      "destination": "/index.html"
    }
  ]
}
